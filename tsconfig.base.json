{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"jsx": "react-jsx",
		"baseUrl": ".",
		"paths": {
			"@mf/shared-utils": ["packages/shared-utils/src"],
			"@mf/shared-react": ["packages/shared-react/src"],
			"@mf/shared-vue": ["packages/shared-vue/src"]
		}
	}
}
